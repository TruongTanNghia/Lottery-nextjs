{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/cron/scrape-daily",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 20 * * 0"
    }
  ],
  "functions": {
    "src/app/api/scrape/all/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/scrape-daily/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/predict/route.ts": {
      "maxDuration": 30
    }
  }
}

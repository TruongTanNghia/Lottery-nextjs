# Turso libSQL credentials (https://turso.tech)
# Run: turso db create lottery && turso db tokens create lottery
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Cron secret (Vercel auto-sets this for /api/cron/* calls)
CRON_SECRET=replace-with-random-string

# Auth — admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
AUTH_SECRET=replace-with-random-string-different-from-cron

# Public-facing app URL (used for self-pinging)
NEXT_PUBLIC_APP_URL=http://localhost:3000
